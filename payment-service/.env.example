# Payment Service Configuration

# Server
PORT=3002
HOST=0.0.0.0
ENVIRONMENT=development

# AWS Configuration
AWS_REGION=us-east-1
USE_LOCALSTACK=true
LOCALSTACK_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# DynamoDB
DYNAMODB_SAGA_TABLE_NAME=PaymentSagas

# EventBridge
EVENTBRIDGE_BUS_NAME=event-management-bus

# SQS
SQS_BOOKING_CREATED_QUEUE_URL=http://localhost:4566/000000000000/booking-created-queue

# Booking Service
BOOKING_SERVICE_URL=http://localhost:3001

# Payment Gateway (Mock)
PAYMENT_GATEWAY_SUCCESS_RATE=0.8
PAYMENT_GATEWAY_TIMEOUT_MS=1000

# Saga Configuration
SAGA_TIMEOUT_SECONDS=300
SAGA_MAX_RETRIES=3
SAGA_RETRY_DELAY_SECONDS=5

# Logging
LOG_LEVEL=INFO
