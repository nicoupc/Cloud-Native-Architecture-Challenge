							"raw": "{\n\t\"name\": \"Rock Concert\",\n\t\"description\": \"Amazing rock concert\",\n\t\"type\": \"CONCERT\",\n\t\"eventDate\": \"2026-12-31T20:00:00\",\n\t\"capacity\": 1000,\n\t\"price\": \"50.00\"\n}",
