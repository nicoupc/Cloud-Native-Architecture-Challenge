		{
			"name": "Notification Service",
			"description": "Python service consuming notifications from SQS (no REST API). Use LocalStack SQS to send test messages.",
			"item": [
				{
					"name": "Send Test Notification to SQS",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "Action",
									"value": "SendMessage",
									"type": "text"
								},
								{
									"key": "MessageBody",
									"value": "{\"type\":\"BOOKING_CONFIRMED\",\"recipient\":\"test@test.com\",\"data\":{\"bookingId\":\"123\",\"eventName\":\"Test\"}}",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{localstack_url}}/000000000000/notification-queue?Action=SendMessage&MessageBody={\"type\":\"BOOKING_CONFIRMED\",\"recipient\":\"test@test.com\",\"data\":{\"bookingId\":\"123\",\"eventName\":\"Test\"}}",
							"host": ["{{localstack_url}}"],
							"path": ["000000000000", "notification-queue"],
							"query": [
								{
									"key": "Action",
									"value": "SendMessage"
								},
								{
									"key": "MessageBody",
									"value": "{\"type\":\"BOOKING_CONFIRMED\",\"recipient\":\"test@test.com\",\"data\":{\"bookingId\":\"123\",\"eventName\":\"Test\"}}"
								}
							]
						},
						"description": "Send a test notification message directly to the SQS notification queue via LocalStack. The Notification Service will pick up and process this message."
					},
					"response": []
				}
			]
		}
