# AWS Configuration (LocalStack)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# SQS Configuration
SQS_QUEUE_URL=http://localhost:4566/000000000000/notification-queue
SQS_DLQ_URL=http://localhost:4566/000000000000/notification-dlq
SQS_MAX_MESSAGES=10
SQS_WAIT_TIME_SECONDS=20
SQS_VISIBILITY_TIMEOUT=30

# EventBridge Configuration
EVENT_BUS_NAME=event-management-bus

# Service Configuration
PORT=3003
LOG_LEVEL=INFO

# Email Configuration (Mock)
EMAIL_FROM=noreply@eventmanagement.com
EMAIL_PROVIDER=mock
